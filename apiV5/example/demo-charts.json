      "columns": [
        { "id": "month", "type": "string", "label": "Tháng" },
        { "id": "actual", "type": "number", "label": "Thực hiện", "colorToken": "series.actual" },
        { "id": "plan", "type": "number", "label": "Kế hoạch", "colorToken": "series.target" }
      ],
      "rows": [
        ["T1", 118, 110],
        ["T2", 132, 120],
        ["T3", 125, 128],
        ["T4", 148, 135],
        ["T5", 160, 145],
        ["T6", 155, 150]
      ]
    },
    "views": [
      {
        "chartType": "line",
        "xField": "month",
        "series": [
          { "field": "actual", "chartType": "line" },
          { "field": "plan", "chartType": "line", "lineType": "dashed" }
        ]
      }
    ]
  },
